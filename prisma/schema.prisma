generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id               String            @id @default(uuid())
    firebaseUid      String            @unique
    name             String
    email            String            @unique
    role             Role              @default(VOLUNTEER)
    createdAt        DateTime          @default(now())
    shiftAssignments ShiftAssignment[]
    swapFulfillments SwapFulfillment[]
    attendance       Attendance[]
}

model TimeBlock {
    id        String   @id @default(uuid())
    name      String // e.g. "Morning", "Midday"
    startTime String // "HH:MM" — must be exactly 1hr before endTime
    endTime   String // "HH:MM"
    createdAt DateTime @default(now())
    shifts    Shift[]
}

model Shift {
    id          String            @id @default(uuid())
    date        DateTime
    timeBlockId String
    committee   String // 'people_ops' | 'purchasing' | 'marketing' | 'collab_edu'
    capacity    Int
    createdAt   DateTime          @default(now())
    timeBlock   TimeBlock         @relation(fields: [timeBlockId], references: [id])
    assignments ShiftAssignment[]
    attendance  Attendance[]
}

model ShiftAssignment {
    id           String        @id @default(uuid())
    userId       String
    shiftId      String
    createdAt    DateTime      @default(now())
    user         User          @relation(fields: [userId], references: [id])
    shift        Shift         @relation(fields: [shiftId], references: [id])
    swapRequests SwapRequest[]
}

model SwapRequest {
    id                String            @id @default(uuid())
    shiftAssignmentId String
    status            SwapStatus        @default(OPEN)
    reason            String?
    createdAt         DateTime          @default(now())
    shiftAssignment   ShiftAssignment   @relation(fields: [shiftAssignmentId], references: [id])
    fulfillments      SwapFulfillment[]
}

model SwapFulfillment {
    id            String      @id @default(uuid())
    swapRequestId String
    volunteerId   String
    createdAt     DateTime    @default(now())
    swapRequest   SwapRequest @relation(fields: [swapRequestId], references: [id])
    volunteer     User        @relation(fields: [volunteerId], references: [id])
}

model Attendance {
    id        String           @id @default(uuid())
    userId    String
    shiftId   String
    status    AttendanceStatus @default(PRESENT)
    notes     String?
    markedBy  String?
    createdAt DateTime         @default(now())
    user      User             @relation(fields: [userId], references: [id])
    shift     Shift            @relation(fields: [shiftId], references: [id])
}

enum Role {
    VOLUNTEER
    ADMIN
}

enum SwapStatus {
    OPEN
    FILLED
    CANCELLED
}

enum AttendanceStatus {
    PRESENT
    ABSENT
    LATE
    EXCUSED
}
